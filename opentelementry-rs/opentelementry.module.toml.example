# Opentelementry Configuration — Module Levels Example (Rust)
# ====================================================

[service]
name = "robot-core"
version = "1.0.0"
environment = "development"
description = "Main robot controller"

[logging]
level = 2

[logging.log]
report_caller = true
report_timestamp = true

[logging.modules.nats-module]
level = 1

[telemetry]
enabled = false

[telemetry.otlp]
enabled = false
