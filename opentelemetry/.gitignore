# ===========================================
# Pulse Observability Stack - Git Ignore
# ===========================================

# ----- Environment & Secrets -----
.env
.env.local
.env.*.local
*.env

# ----- Terraform -----
# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (contain secrets)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Lock file (optional - some prefer to commit this)
.terraform.lock.hcl

# ----- TLS Certificates -----
*.pem
*.key
*.crt
*.csr
certs/

# ----- OS Files -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ----- IDE -----
.idea/
.vscode/
*.swp
*.swo
*~

# ----- Logs -----
*.log
logs/

# ----- Build artifacts -----
dist/
build/
*.exe
*.dll
*.so
*.dylib

# ----- Go -----
vendor/
go.sum

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.eggs/
venv/
.venv/
