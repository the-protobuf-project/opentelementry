# ===========================================
# Pulse Telemetry - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
#
# This is an open-source observability stack.
# See: https://github.com/machanirobotics/pulse

# ----- Grafana Credentials -----
# Change these immediately after deployment!
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ----- Domain Configuration -----
# Main telemetry dashboard domain (Grafana)
DOMAIN=telemetry.example.com
# OTEL collector endpoint domain (for sending telemetry)
OTEL_DOMAIN=otel.example.com

# ----- OTLP Authentication -----
# Bearer token for OTLP ingestion (auto-generated if empty)
# Clients must send: Authorization: Bearer <token>
OTLP_AUTH_TOKEN=

# ----- AWS Configuration (for EC2/EKS deployment) -----
AWS_REGION=us-east-1
# VPC and Subnet (leave empty to use default VPC)
AWS_VPC_ID=
AWS_SUBNET_ID=
# ACM Certificate ARN (for EKS ALB ingress)
ACM_CERTIFICATE_ARN=

# ----- SSH Configuration -----
# Path to your SSH private key for EC2 access
SSH_KEY_PATH=~/.ssh/id_ed25519
# Your SSH public key content (required for Terraform)
SSH_PUBLIC_KEY=ssh-ed25519 AAAA... your-email@example.com

# ----- TLS Certificate paths (for local docker-compose) -----
# Leave empty to auto-generate self-signed certs
TLS_CERT_PATH=./certs/fullchain.pem
TLS_KEY_PATH=./certs/privkey.pem

# ----- Alert Webhook (optional - for local notifications) -----
LOCAL_WEBHOOK_HOST=host.docker.internal
LOCAL_WEBHOOK_PORT=9095

# ----- Website Redirect (optional) -----
# Redirect otel domain root to your main website
REDIRECT_URL=https://example.com
